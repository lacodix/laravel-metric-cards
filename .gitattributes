* text=auto eol=lf

# Keep the built browser bundle in the Composer package.
# dist/metrics.js MUST NOT be export-ignored.
/dist -export-ignore

# Exclude development-only files from the Composer (git archive) package.
# Note: resources/js and package.json intentionally stay in the package.
/.github export-ignore
/tests export-ignore
/.editorconfig export-ignore
/.gitattributes export-ignore
/.gitignore export-ignore
/phpunit.xml.dist export-ignore
/phpstan.neon export-ignore
/rector.php export-ignore
/test.txt export-ignore
